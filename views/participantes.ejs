<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Practica 4 - Participantes</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="app-body">
    <div class="page-shell">
        <div class="page-banner">
            <p class="page-kicker">Mantenimiento de Participantes</p>
            <div class="top-actions">
                <h2>Participantes</h2>
                <a href="/" class="btn btn-secondary">Volver</a>
            </div>
            <p class="page-text">Aquí se puede registrar participantes, buscarlos y editar su información.</p>
        </div>

        <% if(mensaje == "guardado_exitoso") { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                Participante guardado exitosamente.
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>

        <% if (mensaje == "eliminacion_exitosa") { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                Participante eliminado exitosamente.
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>

        
        <% if (mensaje == "actualizacion_exitosa") { %>
            <div class="alert alert-info alert-dismissible fade show" role="alert">
                Participante actualizado exitosamente.
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>

        <div class="panel-card">
            <div class="card-header">Registrar Participante</div>
            <div class="card-body">
                <form action="/participantes/guardar" method="post">
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Nombre</label>
                            <input type="text" name="nombre" class="form-control" required>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Correo</label>
                            <input type="email" name="correo" class="form-control" required>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Teléfono</label>
                            <input type="tel" name="telefono" class="form-control" required>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary">Guardar</button>
                </form>
            </div>
        </div>

         <div class="panel-card mt-4">
            <div class="card-header">Buscar Participante</div>
            <div class="card-body">
                <form action="/participantes" method="GET">
                    <div class="row align-items-end">
                        <div class="col-md-10 mb-2">
                            <label class="form-label">Nombre del participante</label>
                            <input
                                type="text"
                                name="busqueda"
                                class="form-control"
                                placeholder="Ingrese el nombre del participante"
                                value="<%= busqueda %>"
                            >
                        </div>

                        <div class="col-md-2 mb-2">
                            <button type="submit" class="btn btn-success w-100">Buscar</button>
                        </div>
                        <div class="col-md-2 mb-2">
                            <a href="/participantes" class="btn btn-danger w-100">Limpiar</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="panel-card mt-4">
            <div class="card-header">Lista de Participantes</div>
            <div class="card-body">
                <% if (participantes.length > 0) { %>
                    <div class="table-wrap table-responsive">
                        <table class="table table-bordered table-striped">
                            <thead class="table-dark">
                                <tr>
                                    <th>Nombre</th>
                                    <th>Correo</th>
                                    <th>Teléfono</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% participantes.forEach(function(participante) { %>
                                    <tr>
                                        <td><%= participante.nombre %></td>
                                        <td><%= participante.correo %></td>
                                        <td><%= participante.telefono %></td>
                                        <td>
                                            <a href="/participantes/editar/<%= participante._id %>" class="btn btn-warning btn-sm">Editar</a>
                                            <a href="/participantes/eliminar/<%= participante._id %>" class="btn btn-danger btn-sm">Eliminar</a>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="empty-box">
                        <p>No hay participantes registrados.</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>