<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Practica 4 - Editar Participante</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="app-body">
    <div class="page-shell">
        <div class="page-banner">
            <p class="page-kicker">Modificación de Participantes</p>
            <div class="top-actions">
                <h2>Editar Participante</h2>
                <a href="/participantes" class="btn btn-secondary">Volver</a>
            </div>
            <div class="page-text">Se permite cambiar el nombre, correo y teléfono del participante.</div>
        </div>

        <div class="panel-card">
            <div class="card-header">Modificar Datos</div>
            <div class="card-body">
                <form action="/participantes/actualizar/<%= participante._id %>" method="post">
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Nombre</label>
                            <input type="text" name="nombre" class="form-control" value="<%= participante.nombre %>" required>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label">Correo</label>
                            <input type="email" name="correo" class="form-control" value="<%= participante.correo %>" required>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label">Teléfono</label>
                            <input type="tel" name="telefono" class="form-control" value="<%= participante.telefono %>" required>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary">Actualizar</button>
                    <a href="/participantes" class="btn btn-danger ms-2">Cancelar</a>
                </form>
            </div>      
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>