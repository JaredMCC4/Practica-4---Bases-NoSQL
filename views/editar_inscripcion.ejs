<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Practica 4 - Editar Inscripción</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="app-body">
    <div class="page-shell">
        <div class="page-banner">
            <p class="page-kicker">Modificacion de Inscripción</p>
            <div class="top-actions">
                <h2>Editar Inscripción</h2>
                <a href="/inscripciones" class="btn btn-secondary">Volver</a>
            </div>
            <p class="page-text">Se permite modificar el...</p>
        </div>
        <div class="panel-card">
            <div class="card-header">Modificar Datos</div>
            <div class="card-body">
                <form action="/inscripciones/actualizar/<%= inscripcion._id %>" method="post">
                    <div class="row">
                        <div class="col-md-5 mb-3">
                            <label class="form-label">Participante</label>
                            <select name="participanteId" class="form-select" required>
                                <% participantes.forEach(function(participante) { %>
                                        <option value="<%= participante._id %>" <%= participante._id.toString() == inscripcion.participanteId.toString() ? "selected" : "" %>>
                                            <%= participante.nombre %>
                                    </option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-5 mb-3">
                            <label class="form-label">Evento</label>
                            <select name="eventoId" class="form-select" required>
                                <% eventos.forEach(function(evento) { %>
                                    <option value="<%= evento._id %>" <%= evento._id.toString() == inscripcion.eventoId.toString() ? "selected" : "" %>>
                                        <%= evento.nombre %>
                                    </option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-2 mb-3">
                            <label class="form-label">Fecha de Inscripción</label>
                            <input type="date" class="form-control" name="fecha" value="<%= inscripcion.fecha %>" required>
                        </div>
                    </div>
                    <button class="btn btn-primary" type="submit">Actualizar</button>
                    <a href="/inscripciones" class="btn btn-danger ms-2">Cancelar</a>
                </form>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>