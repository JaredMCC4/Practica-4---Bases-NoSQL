<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Practica 4 - Eliminar Participante</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="app-body">
        <div class="page-shell">
            <div class="page-banner">
                <p class="page-kicker">Confirmación de Eliminación de Participante</p>
                <div class="top-actions">
                    <h2>Eliminar Participante</h2>
                    <a href="/participantes" class="btn btn-secondary">Volver</a>
                </div>
                <p class="page-text">¿Esta seguro de que desea borrar este participante?</p>
            </div>

            <div class="panel-card">
                <div class="card-header">Datos del Participante</div>
                <div class="card-body">
                    <div class="alert alert-warning" role="alert">
                        <strong>Advertencia:</strong> Esta acción no se puede deshacer.
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Nombre</label>
                            <input type="text" class="form-control" value="<%= participante.nombre %>" readonly>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Correo</label>
                            <input type="email" class="form-control" value="<%= participante.correo %>" readonly>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label">Teléfono</label>
                            <input type="tel" class="form-control" value="<%= participante.telefono %>" readonly>
                        </div>
                    </div>

                    <form action="/participantes/eliminar/<%= participante._id %>" method="post">
                        <button type="submit" class="btn btn-danger">Eliminar</button>
                        <a href="/participantes" class="btn btn-secondary ms-2">Cancelar</a>
                    </form>
                </div>
            </div>

        </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>